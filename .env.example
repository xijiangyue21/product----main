# ============================================
# StockPulse 环境变量配置
# ============================================

# 数据库配置（使用 Supabase 免费 PostgreSQL）
# 1. 访问 https://supabase.com 注册免费账号
# 2. 创建新项目
# 3. 在 Settings → Database 找到连接字符串
# 4. 替换下面的 DATABASE_URL
DATABASE_URL=postgresql://postgres:你的密码@你的项目ID.supabase.co:5432/postgres

# JWT 密钥（用于加密登录 token）
JWT_SECRET=stockpulse-secret-key-2026-change-this

# 服务器端口
PORT=3000

# ============================================
# 以下为可选配置
# ============================================

# AWS S3 配置（可选，用于文件上传功能）
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET=your-bucket-name

# 环境
NODE_ENV=development

# 多个前端地址（生产部署时用逗号分隔，例如 https://app.example.com）
# CORS_ORIGINS=

# 阿里云市场 API（行情数据，密钥仅放本机 .env）
# ALIYUN_API_APP_KEY=
# ALIYUN_API_APP_SECRET=
# ALIYUN_API_APP_CODE=
# ALIYUN_API_ENDPOINT=https://你的网关.market.alicloudapi.com
