# ============================================
# Core app settings
# ============================================

# Required: MySQL connection string
# Local MySQL example:
# DATABASE_URL=mysql://root:password@localhost:3306/stockpulse?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai
DATABASE_URL=

# Optional when DATABASE_URL is a jdbc:mysql:// URL without embedded credentials
DB_USERNAME=
DB_PASSWORD=

# Required in production. Used to sign JWT tokens.
JWT_SECRET=change-this-to-a-long-random-secret

# Backend server port
PORT=3000

# Runtime environment
NODE_ENV=development

# Optional: allow additional frontend origins, comma-separated
# Example:
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# ============================================
# AWS S3 upload support
# ============================================

AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BUCKET_NAME=

# Optional upload-related business variables used by the Java upload service
FOLDER_NAME=
DOCUMENT_ID=
SUBSCRIPTION_TIER=FREE

# ============================================
# Market search / quote provider
# ============================================

MARKET_API_BASE_URL=
MARKET_API_APP_CODE=

# Optional Alpha Vantage global equity provider
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

# Optional legacy Aliyun endpoint fallback
ALIYUN_API_ENDPOINT=
ALIYUN_API_APP_CODE=

# ============================================
# Aliyun Bailian / DashScope AI advice
# ============================================

BAILIAN_API_KEY=
BAILIAN_MODEL=qwen-plus
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Stock analysis assistant frontend
VITE_STOCK_ASSISTANT_URL=http://localhost:5174/index.html
STOCK_API_BASE_URL=http://localhost:3000
